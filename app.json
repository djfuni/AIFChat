{
  "expo": {
    "name": "AIF Chat",
    "slug": "aif-chat-mobile",
    "scheme": "aifchat",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBFE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "top.aifmusic.chat"
    },
    "android": {
      "package": "top.aifmusic.chat",
      "adaptiveIcon": {
        "backgroundColor": "#FFFBFE",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "permissions": []
    },
    "extra": {
      "apiBaseUrl": "https://api.aifmusic.top",
      "eas": {
        "projectId": "8e4a71cb-e25f-44af-b09d-57ec5aff6328"
      }
    }
  }
}
