# AIF Chat 服务端配置
# 复制此文件为 .env 并填入你的配置

# ====================== 数据库 ======================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aifchat
DB_USER=root
DB_PASS=

# ====================== JWT 密钥 ======================
JWT_SECRET=请修改为随机的64位字符串
JWT_ACCESS_EXPIRES=3600        # Access Token 过期时间（秒）
JWT_REFRESH_EXPIRES=2592000    # Refresh Token 过期时间（秒，默认30天）

# ====================== AI API 配置（默认后端） ======================
# 移动端内置聊天使用的 AI 接口
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=sk-你的OpenAI-API-Key
AI_DEFAULT_MODEL=gpt-4o-mini

# ====================== 邮件服务（用于发送验证码） ======================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=你的SMTP授权码
SMTP_FROM=your@email.com
SMTP_FROM_NAME=AIF Chat

# ====================== 站点配置 ======================
SITE_URL=https://你的域名.com
SITE_NAME=AIF Chat
ADMIN_EMAIL=admin@example.com

# ====================== 安全与限流 ======================
RATE_LIMIT_PER_MINUTE=60      # 每分钟最大请求数（IP 级别）
